<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="todo_activity.MainPage"
             BackgroundColor="#F5F7FA">

    <VerticalStackLayout Spacing="15" Padding="15">

        <Label Text="To Do List App"
               FontSize="24"
               HorizontalTextAlignment="Center"
               FontAttributes="Bold"
               TextColor="#333"/>
        
        <Label Text="Add New Task"
               FontSize="20"
               HorizontalTextAlignment="Center"
               FontAttributes="Bold"
               TextColor="#333"/>
        
        <Border StrokeThickness="0"
                BackgroundColor="White"
                Padding="15">

            <Border.StrokeShape>
                <RoundRectangle CornerRadius="20"/>
            </Border.StrokeShape>

            <VerticalStackLayout Spacing="12">
                
                <Entry x:Name="TitleEntry"
                       Placeholder="Task Title"
                       TextColor="Black"
                       HeightRequest="45"
                       MaxLength="50"/>

                <Editor x:Name="DetailsEditor"
                        Placeholder="Task Details"
                        TextColor="Black"
                        HeightRequest="100"
                        MaxLength="200"/>

                <Button x:Name="AddBtn"
                        Text="Add Task"
                        CornerRadius="15"
                        BackgroundColor="#4CAF50"
                        TextColor="White"
                        HorizontalOptions="Fill"
                        Clicked="AddToDoItem"/>

                <Button x:Name="EditBtn"
                        IsVisible="False"
                        Text="Save Changes"
                        CornerRadius="15"
                        BackgroundColor="#FFC107"
                        TextColor="Black"
                        HorizontalOptions="Fill"
                        Clicked="EditToDoItem"/>

                <Button x:Name="CancelBtn"
                        IsVisible="False"
                        Text="Cancel"
                        CornerRadius="15"
                        BackgroundColor="#F44336"
                        TextColor="White"
                        HorizontalOptions="Fill"
                        Clicked="CancelEdit"/>

            </VerticalStackLayout>

        </Border>

        <Label Text="Task List"
               FontSize="20"
               HorizontalTextAlignment="Center"
               FontAttributes="Bold"
               TextColor="#333"/>
        
        <Label x:Name="EmptyLabel"
               Text="List is currently empty!"
               IsVisible="True"
               FontSize="16"
               HorizontalTextAlignment="Center"
               FontAttributes="Bold"
               TextColor="#333"/>
        
        <ListView x:Name="todoLV"
                  HasUnevenRows="True"
                  SeparatorVisibility="None"
                  BackgroundColor="Transparent"
                  ItemTapped="todoLV_ItemTapped">

            <ListView.ItemTemplate>
                <DataTemplate>
                    <ViewCell>
                        <Border Margin="0,5"
                                Padding="12"
                                BackgroundColor="White">

                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="15"/>
                            </Border.StrokeShape>

                            <Grid ColumnDefinitions="*,Auto"
                                  RowDefinitions="Auto,Auto">

                                <Label Text="{Binding Title}"
                                       FontSize="17"
                                       FontAttributes="Bold"
                                       TextColor="#333"/>

                                <Label Grid.Row="1"
                                       Text="{Binding Detail}"
                                       FontSize="14"
                                       TextColor="#666"/>

                                <Button Grid.Column="1"
                                        Grid.RowSpan="2"
                                        Text="🗑"
                                        FontSize="18"
                                        BackgroundColor="Transparent"
                                        TextColor="#F44336"
                                        ClassId="{Binding Id}"
                                        Clicked="DeleteToDoItem"/>

                            </Grid>

                        </Border>
                    </ViewCell>
                </DataTemplate>
            </ListView.ItemTemplate>

        </ListView>

    </VerticalStackLayout>

</ContentPage>
